\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Overview of treatment effects across all outcomes. \textbf  {A} Estimated treatment effects on the primary outcome (trust in climate scientists, multidimensional scale), ordered from largest to smallest effect. \textbf  {B--C} Treatment effects as heatmaps for secondary and tertiary outcomes, with interventions in the same order as panel A; cell labels show the estimate and BH-adjusted significance stars. \textbf  {D} Treatment effects on donation to the American Meteorological Society (continuous, 0--10 scale). \textbf  {E} Treatment effects on newsletter signup (binary outcome), reported as predicted probabilies from logistic regression. Whiskers in panels A, D, and E depict 95\% CIs without correction for multiple comparisons. In all panels, asterisks indicate BH-adjusted significance: * \(p_{adj}\) \textless {} .05; ** \(p_{adj}\) \textless {} .01; *** \(p_{adj}\) \textless {} .001. Data are simulated at random, thus we should not expect to see any significant effects.}}{24}{figure.caption.21}\protected@file@percent }
\newlabel{fig-treatment-effects}{{3}{24}{Overview of treatment effects across all outcomes. \textbf {A} Estimated treatment effects on the primary outcome (trust in climate scientists, multidimensional scale), ordered from largest to smallest effect. \textbf {B--C} Treatment effects as heatmaps for secondary and tertiary outcomes, with interventions in the same order as panel A; cell labels show the estimate and BH-adjusted significance stars. \textbf {D} Treatment effects on donation to the American Meteorological Society (continuous, 0--10 scale). \textbf {E} Treatment effects on newsletter signup (binary outcome), reported as predicted probabilies from logistic regression. Whiskers in panels A, D, and E depict 95\% CIs without correction for multiple comparisons. In all panels, asterisks indicate BH-adjusted significance: * \(p_{adj}\) \textless {} .05; ** \(p_{adj}\) \textless {} .01; *** \(p_{adj}\) \textless {} .001. Data are simulated at random, thus we should not expect to see any significant effects}{figure.caption.21}{}}
